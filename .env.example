# Server
NODE_ENV=development
PORT=5000

# MongoDB — if password contains $ or other special chars, wrap the whole URI in double quotes:
# MONGODB_URI="mongodb+srv://user:pass$word@cluster/db?opts"

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Verification email — Resend only (https://resend.com)
# You cannot use Gmail/Yahoo as From — only onboarding@resend.dev (testing) or your verified domain.
RESEND_API_KEY=
# Must be quoted if it contains spaces:
RESEND_FROM="Payment Notify <onboarding@resend.dev>"
# Optional alias for RESEND_FROM if you prefer this name in env files
# MAIL_FROM=onboarding@resend.dev

# Public API root (include /api) — used in verification links in emails
API_PUBLIC_URL=http://localhost:5000/api
APP_NAME=Your App

# GET /api/health/email — resendReady

# Frontend URL
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# Keep-alive (Render)
KEEP_ALIVE_URL=
