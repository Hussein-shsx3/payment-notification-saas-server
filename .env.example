# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/payment-notification-saas

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=Payment Notifications <your-email@gmail.com>

# Frontend URL (for verification & reset links)
FRONTEND_URL=http://localhost:3000
# Admin dashboard URL (optional, for links in emails)
ADMIN_URL=http://localhost:5173

# Keep-alive / sleep monitoring
# IMPORTANT: for Render, set KEEP_ALIVE_URL to your public health URL
# e.g. https://your-service.onrender.com/health
KEEP_ALIVE_URL=
