# Server
NODE_ENV=development
PORT=5000

# MongoDB — if password contains $ or other special chars, wrap the whole URI in double quotes:
# MONGODB_URI="mongodb+srv://user:pass$word@cluster/db?opts"

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Email verification (Gmail + Google App Password — not your normal Gmail password)
# 1) Google Account → Security → 2-Step Verification ON
# 2) App passwords → Mail → copy 16 characters (spaces optional in .env)
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
# Optional: "Display Name <same-email-as-GMAIL_USER>"
MAIL_FROM="Your App <you@gmail.com>"
# Base URL of this API (must include /api) — used in verification links
API_PUBLIC_URL=http://localhost:5000/api
APP_NAME=Your App

# GET /api/health/email — env check
# GET /api/health/email/smtp — live SMTP test (may timeout on hosts that block SMTP)

# Frontend URL
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# Keep-alive (Render)
KEEP_ALIVE_URL=
