# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/payment-notification-saas

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Verification email (need at least one working path)
# Resend: https://resend.com — API key + MAIL_FROM on a verified domain
RESEND_API_KEY=
MAIL_FROM=Payment Notify <noreply@yourdomain.com>
# Public API URL used inside the verify link (no trailing slash)
API_PUBLIC_URL=http://localhost:5000/api
APP_NAME=Payment Notify
# Optional Gmail fallback if Resend fails or is not set (Google App Password, not normal password)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Frontend URL
FRONTEND_URL=http://localhost:3000
# Admin dashboard URL
ADMIN_URL=http://localhost:5173

# Keep-alive / sleep monitoring
# IMPORTANT: for Render, set KEEP_ALIVE_URL to your public health URL
# e.g. https://your-service.onrender.com/health
KEEP_ALIVE_URL=
