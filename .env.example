# Server
NODE_ENV=development
PORT=5000

# MongoDB — if password contains $ or other special chars, wrap the whole URI in double quotes:
# MONGODB_URI="mongodb+srv://user:pass$word@cluster/db?opts"

# JWT
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRES_IN=1d
JWT_REFRESH_EXPIRES_IN=30d

# Verification email — production on Render: use Resend (HTTPS). Gmail SMTP often times out there.
#
# Resend (recommended for Render / VPS where outbound SMTP is blocked)
# Get key at resend.com; use onboarding@resend.dev for quick tests, or verify your domain.
RESEND_API_KEY=
# From address: "Name <email@yourdomain.com>" or onboarding@resend.dev for testing
MAIL_FROM="Payment Notify <onboarding@resend.dev>"
#
# Gmail SMTP (works locally or on hosts that allow outbound 465/587)
# Use GOOGLE APP PASSWORD (16 chars), not your normal Gmail password.
# Wrap values with spaces in DOUBLE QUOTES or the password may be truncated.
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
API_PUBLIC_URL=http://localhost:5000/api
APP_NAME=Payment Notify

# Debug (after deploy):
# GET https://YOUR-HOST/api/health/email        — Resend + Gmail env flags
# GET https://YOUR-HOST/api/health/email/smtp   — real SMTP login test (no email sent; may timeout on Render)

# Frontend URL
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# Keep-alive (Render)
KEEP_ALIVE_URL=
